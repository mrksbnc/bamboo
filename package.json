{
	"name": "bamboo-monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"docs:dev": "turbo run docs:dev",
		"type-check": "turbo run type-check",
		"fmt": "pnpm oxfmt --write \"**/*.{ts,md,json,vue}\"",
		"fmt:check": "pnpm oxfmt --check \"**/*.{ts,md,json,vue}\"",
		"lint": "run-p lint:*",
		"lint:spell": "cspell --config ./cspell.yaml \"**/*.{ts,md,json,vue}\" --verbose --show-perf-summary",
		"lint:oxlint": "pnpm oxlint . --fix",
		"test": "turbo run test",
		"purge": "turbo run purge && rm -rf node_modules .turbo",
		"prepare": "husky",
		"ib": "pnpm install && pnpm build"
	},
	"devDependencies": {
		"@cspell/dict-vue": "^3.0.5",
		"@tailwindcss/vite": "^4.1.18",
		"@tsconfig/node22": "^22.0.5",
		"@types/jsdom": "^28.0.0",
		"@types/node": "^25.0.9",
		"@vitest/coverage-v8": "4.0.17",
		"@vue/test-utils": "^2.4.6",
		"@vueuse/core": "^14.1.0",
		"cspell": "^9.6.0",
		"globals": "^17.0.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"jsdom": "^28.0.0",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.35.0",
		"oxlint": "~1.50.0",
		"oxlint-tsgolint": "^0.15.0",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.18",
		"turbo": "^2.8.12",
		"typescript": "^5.9.3",
		"vite": "8.0.0-beta.14",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.0.17",
		"vue": "^3.5.26",
		"vue-tsc": "^3.2.2"
	},
	"packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
